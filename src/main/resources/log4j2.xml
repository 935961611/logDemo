<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <!-- 日志格式 -->
        <property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</property>
        <!-- 日志存放目录 -->
        <property name="LOG_PATH">./logs</property>
        <!-- 日志保留天数：15天 -->
        <property name="LOG_MAX_HISTORY">15</property>
        <!-- 单个日志文件最大大小：500MB -->
        <property name="LOG_MAX_SIZE">500MB</property>
    </Properties>

    <Appenders>
        <!-- 控制台输出 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        ===================== INFO 日志（自动切割 + 自动删除）=====================
        <RollingFile name="InfoFile"
                     fileName="${LOG_PATH}/info.log"
                     filePattern="${LOG_PATH}/info-%d{yyyy-MM-dd}-%i.log.gz">
            <!-- 只输出 INFO 及以上级别 -->
            <ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="${LOG_PATTERN}"/>

            <Policies>
                <!-- 1. 按时间切割：每天一个文件 -->
                <TimeBasedTriggeringPolicy interval="1"/>
                <!-- 2. 按大小切割：单个文件超过 500MB 自动切分 -->
                <SizeBasedTriggeringPolicy size="${LOG_MAX_SIZE}"/>
            </Policies>

            <!-- 3. 自动清理策略：保留最近15天日志，超过自动删除 -->
            <!-- 4. 同一秒最多生成 20 个切分文件 -->
            <DefaultRolloverStrategy max="20" fileIndex="min">
                <Delete basePath="${LOG_PATH}" maxDepth="1">
                    <IfFileName glob="info-*.log.gz"/>
                    <IfLastModified age="${LOG_MAX_HISTORY}d"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        ===================== ERROR 日志（自动切割 + 自动删除）=====================
        <RollingFile name="ErrorFile"
                     fileName="${LOG_PATH}/error.log"
                     filePattern="${LOG_PATH}/error-%d{yyyy-MM-dd}-%i.log.gz">
            <!-- 只输出 ERROR 级别 -->
            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="${LOG_PATTERN}"/>

            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
                <SizeBasedTriggeringPolicy size="${LOG_MAX_SIZE}"/>
            </Policies>

            <DefaultRolloverStrategy max="20" fileIndex="min">
                <Delete basePath="${LOG_PATH}" maxDepth="1">
                    <IfFileName glob="error-*.log.gz"/>
                    <IfLastModified age="${LOG_MAX_HISTORY}d"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

    </Appenders>

    <Loggers>
        <!-- 你的业务包名 -->
        <Logger name="org.tongzhou" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="InfoFile"/>
            <AppenderRef ref="ErrorFile"/>
        </Logger>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>